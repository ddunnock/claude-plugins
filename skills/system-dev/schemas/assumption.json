{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://system-dev.local/schemas/assumption.json",
  "title": "Assumption Slot",
  "type": "object",
  "required": ["slot_id", "slot_type", "version", "created_at", "updated_at", "upstream_id", "description"],
  "properties": {
    "slot_id": {
      "type": "string",
      "pattern": "^assumption:.+$"
    },
    "slot_type": {
      "const": "assumption"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "upstream_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "source_block": {
      "type": "string"
    },
    "related_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rationale": {
      "type": "string"
    },
    "upstream_registered_at": {
      "type": "string"
    },
    "provenance": {
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "upstream_file": { "type": "string" },
        "ingested_at": { "type": "string", "format": "date-time" },
        "hash": { "type": "string" }
      }
    },
    "gap_markers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "finding_ref", "severity", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["missing_data", "schema_mismatch", "known_bug"]
          },
          "finding_ref": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "extensions": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
