{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://system-dev.local/schemas/component.json",
  "title": "Component Slot",
  "type": "object",
  "required": ["slot_id", "slot_type", "name", "version", "created_at", "updated_at"],
  "properties": {
    "slot_id": {
      "type": "string",
      "pattern": "^comp-[a-f0-9-]+$"
    },
    "slot_type": {
      "const": "component"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_block": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "approved", "rejected", "modified", "deprecated"]
    },
    "parent_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requirement_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rationale": {
      "type": ["string", "object"]
    },
    "gap_markers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extensions": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
