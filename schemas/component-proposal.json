{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://system-dev.local/schemas/component-proposal.json",
  "title": "Component Proposal Slot",
  "type": "object",
  "required": [
    "slot_id",
    "slot_type",
    "name",
    "description",
    "version",
    "created_at",
    "updated_at",
    "status",
    "requirement_ids",
    "proposal_session_id"
  ],
  "properties": {
    "slot_id": {
      "type": "string",
      "pattern": "^cprop-[a-f0-9-]+$"
    },
    "slot_type": {
      "const": "component-proposal"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "rejected", "modified"]
    },
    "requirement_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rationale": {
      "type": "object",
      "properties": {
        "narrative": {
          "type": "string"
        },
        "grouping_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "req_id": {
                "type": "string"
              },
              "relevance": {
                "type": "string"
              }
            },
            "required": ["req_id", "relevance"],
            "additionalProperties": false
          }
        }
      },
      "required": ["narrative"],
      "additionalProperties": false
    },
    "gap_markers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "finding_ref": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["type", "finding_ref", "severity", "description"],
        "additionalProperties": false
      },
      "default": []
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target_proposal": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["target_proposal", "type", "description"],
        "additionalProperties": false
      }
    },
    "decision": {
      "type": "object",
      "properties": {
        "action": {
          "type": ["string", "null"],
          "enum": ["accept", "reject", "modify", null]
        },
        "decided_by": {
          "type": ["string", "null"]
        },
        "decided_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "notes": {
          "type": ["string", "null"]
        },
        "rejection_rationale": {
          "type": ["string", "null"]
        },
        "modifications": {
          "type": ["object", "null"]
        },
        "committed_slot_id": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "proposal_session_id": {
      "type": "string"
    },
    "extensions": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
